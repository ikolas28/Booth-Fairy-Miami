{
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/crm/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/crm/index.html"
    },
    {
      "source": "/admin/styles.css",
      "destination": "/crm/styles.css"
    },
    {
      "source": "/admin/script.js",
      "destination": "/crm/script.js"
    },
    {
      "source": "/",
      "destination": "/website/index.html"
    },
    {
      "source": "/styles.css",
      "destination": "/website/styles.css"
    },
    {
      "source": "/script.js",
      "destination": "/website/script.js"
    },
    {
      "source": "/thank-you.html",
      "destination": "/website/thank-you.html"
    },
    {
      "source": "/wedding-photo-booth-miami.html",
      "destination": "/website/wedding-photo-booth-miami.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/website/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/website/sitemap.xml"
    },
    {
      "source": "/google04f5f8c2c05f04bb.html",
      "destination": "/website/google04f5f8c2c05f04bb.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/website/assets/:path*"
    }
  ],
  "headers": [
    {
      "source": "/admin(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://formspree.io; script-src 'self' 'unsafe-inline' https://connect.facebook.net https://code.tidio.co https://*.tidio.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://formspree.io https://connect.facebook.net https://www.facebook.com https://*.tidio.co wss://*.tidio.co https://hwwhyrpwfewxevocjjzk.supabase.co; frame-src 'self' https://*.tidio.co; media-src 'self' https:; manifest-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ]
}
